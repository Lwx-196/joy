# VLM primary configuration.
# Keep real secrets in .env, not in this file.
VLM_PROVIDER=vertex
VLM_MODEL=gemini-2.5-flash
VLM_API_KEY=
VLM_ENDPOINT=

# Production retry/rate knobs. Keep conservative until live batch reports prove stability.
VLM_MAX_CONCURRENCY=3
VLM_REQUESTS_PER_MINUTE=0
VLM_RETRY_MAX_ATTEMPTS=3
VLM_RETRY_BASE_SECONDS=1
VLM_RETRY_MAX_SECONDS=30

# Vertex AI ADC path. VLM_REQUEST_TYPE=dedicated only after live readiness is verified.
VLM_PROJECT=
VLM_LOCATION=us-central1
VLM_REQUEST_TYPE=

# Backup/probe provider. Do not promote backup provider without a live smoke report.
VLM_BACKUP_PROVIDER=flashapi
VLM_BACKUP_ENDPOINT=https://ai.flashapi.top/v1
VLM_BACKUP_MODEL=
VLM_BACKUP_API_KEY=
VLM_OPENAI_COMPATIBLE_API=

# Backward-compatible variables still read by VLMProvider.
CASE_WORKBENCH_VLM_JUDGE_PROVIDER=
CASE_WORKBENCH_VLM_JUDGE_MODEL=
CASE_WORKBENCH_VLM_JUDGE_API_KEY=
CASE_WORKBENCH_VLM_JUDGE_ENDPOINT=
CASE_WORKBENCH_VLM_JUDGE_BASE_URL=
CASE_WORKBENCH_VLM_JUDGE_API_FORMAT=
CASE_WORKBENCH_VERTEX_PROJECT=
CASE_WORKBENCH_VERTEX_LOCATION=
CASE_WORKBENCH_VERTEX_REQUEST_TYPE=
VISION_PROVIDER=
VISION_API_BASE=
VISION_API_KEY=
VISION_API_MODEL=
VISION_BACKUP_BASE_URL=
VISION_BACKUP_MODEL=
GEMINI_TUZI_API_KEY=
TUZI_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# DeepSeek official API for text-only execution coordination.
# It is advisory only and must not replace VLM image judgment or production gates.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_RETRY_MAX_ATTEMPTS=3
DEEPSEEK_RETRY_BASE_SECONDS=1
DEEPSEEK_RETRY_MAX_SECONDS=30
