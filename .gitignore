# Python
.venv/
__pycache__/
*.pyc
*.pyo

# Local environment / secrets
.env
.env.*
!.env.example

# Node
node_modules/

# Frontend build / test artifacts
frontend/dist/
frontend/test-results/
frontend/playwright-report/
frontend/*.tsbuildinfo
frontend/**/*.tsbuildinfo

# Project-root test artifacts (Playwright leaves traces here too)
test-results/
stress-results/
.context/

# Live database (CI uses tests/fixtures/case-workbench.test.db instead)
case-workbench.db
case_workbench.db
cases.db
*.db.schema.lock

# Backend test artifacts
backend/.pytest_cache/
.pytest_cache/

# Local AI simulation artifacts
# Pattern uses /* (not /) so git can still descend and honor the negation below.
case-workbench-ai/*
# Exception: promotion manifest is SSoT (approval + hash bindings), tracked.
!case-workbench-ai/promotion/
!case-workbench-ai/promotion/**

# Wave 4 K-8: SLO paused-state sidecar is RUNTIME state (per-deployment,
# ops-managed). Tracking it would pollute commit history with 15-min timer
# updates AND inject a stale paused_since anchor on fresh checkouts.
# Lock file + pid+uuid-namespaced tmp files (K-1 concurrent-write fix)
# excluded too.
/case-workbench-ai/promotion/slo_paused_state.json
/case-workbench-ai/promotion/slo_paused_state.json.lock
/case-workbench-ai/promotion/slo_paused_state.json.*.tmp

# Delivery render outputs (large JPGs); only manifests + report are tracked
delivery/body/
delivery/standard_face/
delivery/*/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log

# Local Claude Code project metadata
.claude/

# Claude Code workstation artifacts (do not commit to business repo)
/memory/
/tasks/

# Allowlist fixture DB (override case-workbench.db ignore)
!tests/fixtures/case-workbench.test.db
