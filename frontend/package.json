{
  "name": "case-workbench-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test:e2e": "playwright test",
    "test:e2e:local-mainline": "PLAYWRIGHT_BASE_URL=http://127.0.0.1:5292 API_PROXY_TARGET=http://127.0.0.1:5291 playwright test",
    "test:e2e:stress": "PLAYWRIGHT_BASE_URL=http://127.0.0.1:5292 API_PROXY_TARGET=http://127.0.0.1:5291 playwright test tests/e2e/stress-smoke.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-virtual": "^3.13.24",
    "axios": "^1.7.0",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.6",
    "react-router-dom": "^7.1.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "axe-core": "^4.11.3",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.0.0"
  }
}
